{
  "name": "crypto-amm",
  "version": "1.0.0",
  "description": "Automated Market Maker for Cryptocurrency",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "nodemon src/backend/server.js",
    "dev:frontend": "cd frontend && npm start",
    "build": "cd frontend && npm run build",
    "test": "jest",
    "test:contracts": "hardhat test",
    "compile": "hardhat compile",
    "deploy": "hardhat run scripts/deploy.js --network localhost"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.3.0",
    "bignumber.js": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.8.1",
    "express": "^4.18.2",
    "uuid": "^9.0.1",
    "web3": "^4.2.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.20",
    "@types/node": "^20.8.0",
    "@types/uuid": "^9.0.6",
    "concurrently": "^8.2.2",
    "hardhat": "^2.17.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "crypto",
    "amm",
    "defi",
    "ethereum",
    "smart-contracts"
  ],
  "author": "Your Name",
  "license": "MIT"
}
